  "primitive/shadow": {
    "shadow": {
      "xs": { "$value": [{ "x": 0, "y": 1, "blur": 2, "spread": 0, "color": "rgba(0,0,0,0.04)", "type": "dropShadow" }], "$type": "boxShadow", "$description": "minimal shadow" },
